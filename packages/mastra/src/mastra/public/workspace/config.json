{
  "version": "1.0.0",
  "workspace": "mocean-ai-workspace",
  "description": "Mocean Multi-Agent Workspace",
  "created": "2026-03-29",
  "environments": {
    "development": {
      "apiUrl": "http://localhost:3000",
      "debug": true
    },
    "production": {
      "apiUrl": "https://api.mocean.ai",
      "debug": false
    }
  },
  "defaultAgent": "customer-service-agent",
  "maxConcurrentAgents": 10,
  "memoryConfig": {
    "type": "hybrid",
    "persistence": true,
    "ttl": 86400
  }
}
