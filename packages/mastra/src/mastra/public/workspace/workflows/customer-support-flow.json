{
  "id": "customer-support-flow",
  "name": "Customer Support Workflow",
  "version": "2.0.0",
  "description": "End-to-end customer support workflow",
  "trigger": "customer_inquiry",
  "steps": [
    {
      "id": "step_1",
      "name": "Receive Inquiry",
      "type": "trigger",
      "action": "receive_message"
    },
    {
      "id": "step_2",
      "name": "Analyze Intent",
      "type": "agent_action",
      "agent": "customer-service-agent",
      "actions": ["sentiment_analysis", "intent_classification"],
      "timeout": 30
    },
    {
      "id": "step_3",
      "name": "Route to Handler",
      "type": "conditional",
      "condition": "sentiment < -0.5 || complexity > 7",
      "onTrue": "escalate",
      "onFalse": "handle"
    },
    {
      "id": "handle",
      "name": "Handle with Customer Service",
      "type": "agent_action",
      "agent": "customer-service-agent",
      "tools": ["search-orders", "check-inventory"],
      "maxRetries": 3
    },
    {
      "id": "escalate",
      "name": "Escalate to Human",
      "type": "agent_action",
      "agent": "escalation-agent",
      "actions": ["create-ticket", "notify-team"],
      "sla": 3600
    },
    {
      "id": "step_5",
      "name": "Send Response",
      "type": "action",
      "action": "send_message",
      "channel": "user_channel"
    },
    {
      "id": "step_6",
      "name": "Log Interaction",
      "type": "action",
      "action": "persist_to_memory",
      "memoryKey": "customer_interactions"
    }
  ],
  "errorHandling": {
    "onError": "escalate",
    "maxRetries": 3,
    "backoffStrategy": "exponential"
  },
  "monitoring": {
    "logLevel": "info",
    "metrics": ["duration", "success_rate", "escalation_rate"]
  }
}
