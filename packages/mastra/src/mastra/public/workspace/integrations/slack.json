{
  "id": "slack-integration",
  "name": "Slack Integration",
  "type": "messaging",
  "version": "1.0.0",
  "description": "Send notifications and receive messages from Slack",
  "enabled": true,
  "config": {
    "webhookUrl": "${SLACK_WEBHOOK_URL}",
    "botToken": "${SLACK_BOT_TOKEN}",
    "channels": {
      "notifications": "#ai-agent-notifications",
      "escalations": "#escalations",
      "analytics": "#daily-analytics"
    }
  },
  "events": {
    "onEscalation": {
      "channel": "escalations",
      "messageTemplate": "escalation_alert"
    },
    "onAnalyticsReady": {
      "channel": "analytics",
      "messageTemplate": "daily_summary"
    }
  },
  "rateLimit": {
    "maxRequests": 30,
    "windowMs": 60000
  }
}
